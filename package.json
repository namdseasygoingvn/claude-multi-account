{
  "name": "claude-multi-account",
  "version": "0.1.0",
  "description": "Native macOS menu-bar app that watches Claude Code usage quota across multiple accounts — drives real `claude` REPLs over PTYs and runs /usage for each.",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node scripts/fix-pty-perms.mjs",
    "build": "tsc",
    "app": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "rebuild:pty": "electron-rebuild -f -w node-pty",
    "gen-icons": "node scripts/gen-icons.mjs",
    "dist": "npm run build && electron-builder",
    "spike": "tsx scripts/spike.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "fix-path": "^5.0.0",
    "node-pty": "^1.0.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.10.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "vn.easygoing.claudequota",
    "productName": "Claude Quota Monitor",
    "npmRebuild": false,
    "electronLanguages": ["en"],
    "directories": {
      "output": "dist-app"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "namdseasygoingvn",
        "repo": "claude-multi-account"
      }
    ],
    "files": [
      "dist/**",
      "web/**",
      "assets/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "assets/icon.png",
      "identity": "-",
      "hardenedRuntime": false,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "ClaudeQuotaMonitor-${version}-${arch}-setup.${ext}"
    }
  }
}
